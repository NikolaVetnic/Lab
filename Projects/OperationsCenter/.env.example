# Operations Center local environment example
# Copy values into your shell or .env tool for local development only.

# API settings
ASPNETCORE_ENVIRONMENT=Development

# Database
ConnectionStrings__OperationsCenterDatabase=Host=localhost;Port=5432;Database=operations_center;Username=operations_center;Password=operations_center

# JWT
Jwt__Issuer=OperationsCenter.Dev
Jwt__Audience=OperationsCenter.Api
Jwt__SigningKey=replace-with-a-long-random-development-key
Jwt__AccessTokenExpiryMinutes=180

# Development seed user passwords
DEV_SEED_ADMIN_PASSWORD=Admin123!
DEV_SEED_OPERATOR_PASSWORD=Operator123!
DEV_SEED_VIEWER_PASSWORD=Viewer123!
