# Operations Center local environment example
# Copy this file to .env for local development and demo containers only.
# These values are intentionally non-production and must never be reused in production.

# Host ports
API_PORT=5000
WEB_PORT=8080
POSTGRES_PORT=5432

# Observability host ports
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=8889
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
SEQ_PORT=5341

# Grafana admin credentials (dev-only, provisioned on first container start)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# API settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:8080

# PostgreSQL container settings
POSTGRES_DB=operations_center
POSTGRES_USER=operations_center
POSTGRES_PASSWORD=operations_center

# Database override for non-container dotnet run workflows
ConnectionStrings__OperationsCenterDatabase=Host=localhost;Port=5432;Database=operations_center;Username=operations_center;Password=operations_center

# JWT
Jwt__Issuer=OperationsCenter.Dev
Jwt__Audience=OperationsCenter.Api
Jwt__SigningKey=replace-with-a-long-random-development-key-for-local-only
Jwt__AccessTokenExpiryMinutes=180

# Development seed user passwords used by the one-shot compose migration service
DEV_SEED_ADMIN_PASSWORD=Admin123!
DEV_SEED_OPERATOR_PASSWORD=Operator123!
DEV_SEED_VIEWER_PASSWORD=Viewer123!

# OpenTelemetry / observability
# Telemetry is enabled for the containerized stack and pushed to the OpenTelemetry
# Collector over OTLP. The API starts and serves traffic normally even if the
# Collector is temporarily unavailable.
OpenTelemetry__Enabled=true
OpenTelemetry__ServiceName=operations-center-api
OpenTelemetry__ServiceVersion=1.0.0
OpenTelemetry__OtlpEndpoint=http://operations-center-otel-collector:4317
