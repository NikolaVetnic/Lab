{
  "ConnectionStrings": {
    "OperationsCenterDatabase": ""
  },
  "Jwt": {
    "Issuer": "OperationsCenter",
    "Audience": "OperationsCenter.Api",
    "SigningKey": "replace-with-env-var-jwt-signing-key-for-non-dev",
    "AccessTokenExpiryMinutes": 60
  },
  "OpenTelemetry": {
    "Enabled": false,
    "ServiceName": "operations-center-api",
    "ServiceVersion": "1.0.0",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
